#!/usr/bin/env python3
import sys
import json
import re

if len(sys.argv) < 2:
  sys.exit("env file required as argument")

env_file = sys.argv[1]

data = {}

p = re.compile(r'^([A-Za-z_][A-Za-z0-9_]*)=(.*)$')

with open(env_file, 'r') as f:
  for i, line in enumerate(f, 1):
    l = line.strip()

    if not l or l.startswith('#'):
        continue

    m = p.match(l)
    if not m:
      sys.exit("corrupt env file")

    key, value = m.groups()
    data[key.lower()] = value

print(json.dumps(data, separators=(',', ':')))
