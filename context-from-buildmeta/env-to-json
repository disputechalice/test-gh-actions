#!/usr/bin/bash
set -e
trap 'echo >&2 E$? L$LINENO' ERR

ENV_FILE="${1:?env file required}"

json='{}'

while IFS= read -r line || [[ -n "$line" ]]; do
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"

  [[ -z "$line" || "$line" =~ ^# ]] && continue

  [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]
  key="${BASH_REMATCH[1]}"
  value="${BASH_REMATCH[2]}"

  json=$(jq --arg k "${key,,}" --arg v "$value" \
    '. + {($k): $v}' <<< "$json")

done < "$ENV_FILE"

jq -c . <<< "$json"
